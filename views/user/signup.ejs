<% layout("layout/boilerplate") %>

<!-- AUTH WRAPPER -->
<main class="auth-page">
  <!-- LEFT PANEL -->
  <div class="auth-left" aria-hidden="true">
    <div class="auth-left-inner">
      <div class="auth-brand">
        <span class="auth-brand-logo">RentPe</span>
        <p class="auth-brand-tag">Join thousands of hosts & travellers.</p>
      </div>

      <div class="auth-features">
        <div class="auth-feature">
          <div class="auth-feature-icon">🏨</div>
          <div>
            <div class="auth-feature-title">List your property</div>
            <div class="auth-feature-desc">
              Publish in minutes, start earning today
            </div>
          </div>
        </div>
        <div class="auth-feature">
          <div class="auth-feature-icon">⚡</div>
          <div>
            <div class="auth-feature-title">Instant bookings</div>
            <div class="auth-feature-desc">No waiting, direct reservations</div>
          </div>
        </div>
        <div class="auth-feature">
          <div class="auth-feature-icon">🛡️</div>
          <div>
            <div class="auth-feature-title">Verified & secure</div>
            <div class="auth-feature-desc">
              Every listing reviewed before going live
            </div>
          </div>
        </div>
        <div class="auth-feature">
          <div class="auth-feature-icon">💰</div>
          <div>
            <div class="auth-feature-title">Transparent pricing</div>
            <div class="auth-feature-desc">
              No hidden fees, pay what you see
            </div>
          </div>
        </div>
      </div>

      <div class="auth-stats">
        <div class="auth-stat">
          <div class="auth-stat-num">250+</div>
          <div class="auth-stat-label">Listings</div>
        </div>
        <div class="auth-stat">
          <div class="auth-stat-num">4.9★</div>
          <div class="auth-stat-label">Avg Rating</div>
        </div>
        <div class="auth-stat">
          <div class="auth-stat-num">98%</div>
          <div class="auth-stat-label">Response</div>
        </div>
      </div>
    </div>
  </div>

  <!-- RIGHT PANEL — FORM -->
  <div class="auth-right">
    <div class="auth-card">
      <div class="auth-card-header">
        <div class="auth-eyebrow">
          <div class="eyebrow-dot"></div>
          Get started free
        </div>
        <h1 class="auth-title">
          Create your<br /><span class="accent">account</span>
        </h1>
        <p class="auth-subtitle">
          Already have an account?
          <a href="/login" class="auth-link">Sign in →</a>
        </p>
      </div>

      <!-- SOCIAL SIGNUP -->
      <div class="social-row">
        <button
          class="social-btn"
          type="button"
          disabled
          style="cursor: not-allowed"
          title="Coming Soon"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path
              d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
              fill="#4285F4"
            />
            <path
              d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
              fill="#34A853"
            />
            <path
              d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"
              fill="#FBBC05"
            />
            <path
              d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
              fill="#EA4335"
            />
          </svg>
          Sign up with Google
        </button>
        <button
          class="social-btn"
          type="button"
          disabled
          style="cursor: not-allowed"
          title="Coming Soon"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="#1877F2">
            <path
              d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
            />
          </svg>
          Sign up with Facebook
        </button>
      </div>

      <div class="divider-row">
        <span class="divider-line"></span>
        <span class="divider-text">or fill in your details</span>
        <span class="divider-line"></span>
      </div>

      <% if(error && error.length > 0) { %>
        <div class="toast-msg  invalid-detail-error">
          <i class="fa-solid fa-exclamation"></i>
          <span><%= error %></span>
        </div>
      <% } %>

      <!-- FORM -->
      <form
        action="/signup"
        method="POST"
        class="auth-form"
        id="signupForm"
        novalidate
      >
        <div class="form-row-2">
          <div class="form-group">
            <label class="form-label" for="fname">First name</label>
            <div class="input-wrap">
              <svg
                class="input-icon"
                width="16"
                height="16"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                <circle cx="12" cy="7" r="4" />
              </svg>
              <input
                class="form-input"
                type="text"
                id="fname"
                name="fname"
                placeholder="Riya"
                required
                autocomplete="given-name"
              />
            </div>
            <div class="form-error" id="fnameError">Enter your first name.</div>
          </div>
          <div class="form-group">
            <label class="form-label" for="lname">Last name</label>
            <div class="input-wrap">
              <svg
                class="input-icon"
                width="16"
                height="16"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                <circle cx="12" cy="7" r="4" />
              </svg>
              <input
                class="form-input"
                type="text"
                id="lname"
                name="lname"
                placeholder="Sharma"
                required
                autocomplete="family-name"
              />
            </div>
            <div class="form-error" id="lnameError">Enter your last name.</div>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="email">Email address</label>
          <div class="input-wrap">
            <svg
              class="input-icon"
              width="16"
              height="16"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              />
              <polyline points="22,6 12,12 2,6" />
            </svg>
            <input
              class="form-input"
              type="email"
              id="email"
              name="email"
              placeholder="you@example.com"
              required
              autocomplete="email"
            />
          </div>
          <div class="form-error" id="emailError">
            Please enter a valid email.
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="password">Password</label>
          <div class="input-wrap">
            <svg
              class="input-icon"
              width="16"
              height="16"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
              <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
            <input
              class="form-input"
              type="password"
              id="password"
              name="password"
              placeholder="Min. 8 characters"
              required
              autocomplete="new-password"
              oninput="checkStrength(this.value)"
            />
            <button
              type="button"
              class="toggle-pw"
              onclick="togglePw('password', this)"
              aria-label="Show password"
            >
              <svg
                width="16"
                height="16"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
            </button>
          </div>
          <div class="strength-bar" id="strengthBar">
            <div class="strength-fill" id="strengthFill"></div>
          </div>
          <div class="strength-label" id="strengthLabel"></div>
          <div class="form-error" id="passwordError">
            Password must be at least 8 characters.
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="confirm">Confirm password</label>
          <div class="input-wrap">
            <svg
              class="input-icon"
              width="16"
              height="16"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
              <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
            <input
              class="form-input"
              type="password"
              id="confirm"
              placeholder="Re-enter password"
              required
              autocomplete="new-password"
            />
            <button
              type="button"
              class="toggle-pw"
              onclick="togglePw('confirm', this)"
              aria-label="Show password"
            >
              <svg
                width="16"
                height="16"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
            </button>
          </div>
          <div class="form-error" id="confirmError">
            Passwords do not match.
          </div>
        </div>

        <div class="form-check-row">
          <label class="check-label">
            <input type="checkbox" class="check-input" id="terms" required />
            <span class="check-box"></span>
            I agree to the
            <a href="#" class="auth-link">Terms of Service</a> and
            <a href="#" class="auth-link">Privacy Policy</a>
          </label>
        </div>
        <div class="form-error" id="termsError" style="margin-top: -8px">
          You must accept the terms.
        </div>

        <button type="submit" class="btn-auth">
          <span class="btn-auth-text">Create Account</span>
          <svg
            class="btn-auth-arrow"
            width="16"
            height="16"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </button>
      </form>

      <p class="auth-footer-note">
        No credit card required. Free forever for travellers.
      </p>
    </div>
  </div>
</main>

<script>
  function checkStrength(val) {
    const fill = document.getElementById("strengthFill");
    const label = document.getElementById("strengthLabel");
    const bar = document.getElementById("strengthBar");
    bar.style.display = val.length ? "block" : "none";
    let score = 0;
    if (val.length >= 8) score++;
    if (/[A-Z]/.test(val)) score++;
    if (/[0-9]/.test(val)) score++;
    if (/[^A-Za-z0-9]/.test(val)) score++;
    const levels = [
      { pct: "25%", color: "#e05", text: "Weak" },
      { pct: "50%", color: "#f90", text: "Fair" },
      { pct: "75%", color: "#fb0", text: "Good" },
      { pct: "100%", color: "#2a9", text: "Strong" },
    ];
    const l = levels[score - 1] || levels[0];
    fill.style.width = l.pct;
    fill.style.background = l.color;
    label.textContent = l.text;
    label.style.color = l.color;
  }

  let form = document.getElementById("signupForm");
  form.addEventListener("submit", function (e) {
    e.preventDefault();
    let valid = true;
    const fields = ["fname", "lname", "email", "password", "confirm"];
    fields.forEach((id) => {
      document.getElementById(id + "Error").classList.remove("show");
      document.getElementById(id).classList.remove("input-error");
    });
    document.getElementById("termsError").classList.remove("show");

    if (!document.getElementById("fname").value.trim()) {
      err("fname");
      valid = false;
    }
    if (!document.getElementById("lname").value.trim()) {
      err("lname");
      valid = false;
    }
    const em = document.getElementById("email");
    if (!em.value || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(em.value)) {
      err("email");
      valid = false;
    }
    const pw = document.getElementById("password");
    if (!pw.value || pw.value.length < 8) {
      err("password");
      valid = false;
    }
    const cf = document.getElementById("confirm");
    if (!cf.value || cf.value !== pw.value) {
      document.getElementById("confirmError").classList.add("show");
      cf.classList.add("input-error");
      valid = false;
    }
    if (!document.getElementById("terms").checked) {
      document.getElementById("termsError").classList.add("show");
      valid = false;
    }
    if (valid) {
      const btn = this.querySelector(".btn-auth");
      btn.classList.add("loading");
      btn.querySelector(".btn-auth-text").textContent = "Creating account…";
      form.submit();
    }
  });
  function err(id) {
    document.getElementById(id + "Error").classList.add("show");
    document.getElementById(id).classList.add("input-error");
  }
</script>
