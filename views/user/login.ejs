<% layout("layout/boilerplate") %>

<!-- AUTH WRAPPER -->
<main class="auth-page">
  <!-- LEFT PANEL -->
  <div class="auth-left" aria-hidden="true">
    <div class="auth-left-inner">
      <div class="auth-brand">
        <span class="auth-brand-logo">RentPe</span>
        <p class="auth-brand-tag">Trusted stays, better hosting.</p>
      </div>
      <div class="auth-testimonial">
        <p class="auth-testimonial-text">
          "Found the perfect hotel in Bareilly within minutes. The booking was
          instant and the host was incredibly responsive."
        </p>
        <div class="auth-testimonial-author">
          <div class="auth-testimonial-avatar">R</div>
          <div>
            <div class="auth-testimonial-name">Riya Sharma</div>
            <div class="auth-testimonial-role">Traveller, Delhi</div>
          </div>
        </div>
      </div>
      <div class="auth-stats">
        <div class="auth-stat">
          <div class="auth-stat-num">250+</div>
          <div class="auth-stat-label">Listings</div>
        </div>
        <div class="auth-stat">
          <div class="auth-stat-num">4.9★</div>
          <div class="auth-stat-label">Avg Rating</div>
        </div>
        <div class="auth-stat">
          <div class="auth-stat-num">98%</div>
          <div class="auth-stat-label">Response</div>
        </div>
      </div>
    </div>
  </div>

  <!-- RIGHT PANEL — FORM -->
  <div class="auth-right">
    <div class="auth-card">
      <div class="auth-card-header">
        <div class="auth-eyebrow">
          <div class="eyebrow-dot"></div>
          Welcome back
        </div>
        <h1 class="auth-title">
          Sign in to<br /><span class="accent">RentPe</span>
        </h1>
        <p class="auth-subtitle">
          Don't have an account?
          <a href="/signup" class="auth-link">Sign up free →</a>
        </p>
      </div>

      <!-- SOCIAL LOGIN -->
      <div class="social-row">
        <button
          class="social-btn"
          type="button"
          disabled
          style="cursor: not-allowed"
          title="Coming Soon"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path
              d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
              fill="#4285F4"
            />
            <path
              d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
              fill="#34A853"
            />
            <path
              d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"
              fill="#FBBC05"
            />
            <path
              d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
              fill="#EA4335"
            />
          </svg>
          Continue with Google
        </button>
        <button
          class="social-btn"
          type="button"
          disabled
          style="cursor: not-allowed"
          title="Coming Soon"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="#1877F2">
            <path
              d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
            />
          </svg>
          Continue with Facebook
        </button>
      </div>

      <div class="divider-row">
        <span class="divider-line"></span>
        <span class="divider-text">or sign in with email</span>
        <span class="divider-line"></span>
      </div>

      <% if(error && error.length > 0) { %>
        <div class="toast-msg  invalid-detail-error">
          <i class="fa-solid fa-exclamation"></i>
          <span><%= error %></span>
        </div>
      <% } %>

      <!-- FORM -->
      <form
        action="/login"
        method="POST"
        class="auth-form"
        id="loginForm"
        novalidate
      >
        <div class="form-group">
          <label class="form-label" for="email">Email address</label>
          <div class="input-wrap">
            <svg
              class="input-icon"
              width="16"
              height="16"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              />
              <polyline points="22,6 12,12 2,6" />
            </svg>
            <input
              class="form-input"
              type="email"
              id="email"
              name="email"
              placeholder="you@example.com"
              required
              autocomplete="email"
            />
          </div>
          <div class="form-error" id="emailError">
            Please enter a valid email.
          </div>
        </div>

        <div class="form-group">
          <div class="form-label-row">
            <label class="form-label" for="password">Password</label>
            <a
              href="#"
              class="auth-link forgot-link"
              style="cursor: not-allowed"
              >Forgot password?</a
            >
          </div>
          <div class="input-wrap">
            <svg
              class="input-icon"
              width="16"
              height="16"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
              <path d="M7 11V7a5 5 0 0 1 10 0v4" />
            </svg>
            <input
              class="form-input"
              type="password"
              id="password"
              name="password"
              placeholder="••••••••"
              required
              autocomplete="current-password"
            />
            <button
              type="button"
              class="toggle-pw"
              onclick="togglePw('password', this)"
              aria-label="Show password"
            >
              <svg
                width="16"
                height="16"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
            </button>
          </div>
          <div class="form-error" id="passwordError">
            Password must be at least 6 characters.
          </div>
        </div>

        <div class="form-check-row">
          <label class="check-label">
            <input type="checkbox" class="check-input" id="remember" />
            <span class="check-box"></span>
            Remember me for 30 days
          </label>
        </div>

        <button class="btn-auth">
          <span class="btn-auth-text">Sign In</span>
          <svg
            class="btn-auth-arrow"
            width="16"
            height="16"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </button>
      </form>

      <p class="auth-footer-note">
        By continuing, you agree to RentPe's
        <a href="#" class="auth-link">Terms</a> and
        <a href="#" class="auth-link">Privacy Policy</a>.
      </p>
    </div>
  </div>
</main>

<script>
  let form = document.getElementById("loginForm");
  form.addEventListener("submit", function (e) {
    e.preventDefault();
    let valid = true;
    const email = document.getElementById("email");
    const password = document.getElementById("password");
    document.getElementById("emailError").classList.remove("show");
    document.getElementById("passwordError").classList.remove("show");
    if (!email.value || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) {
      document.getElementById("emailError").classList.add("show");
      email.classList.add("input-error");
      valid = false;
    } else {
      email.classList.remove("input-error");
    }
    if (!password.value || password.value.length < 6) {
      document.getElementById("passwordError").classList.add("show");
      password.classList.add("input-error");
      valid = false;
    } else {
      password.classList.remove("input-error");
    }
    if (valid) {
      const btn = this.querySelector(".btn-auth");
      btn.classList.add("loading");
      btn.querySelector(".btn-auth-text").textContent = "Signing in…";
      form.submit();
    }
  });
</script>
