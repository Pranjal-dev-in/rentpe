<% layout("layout/boilerplate.ejs") %>

<% if(allListing.length>0) {%>
<section id="listings" class="container pb-5 mt-3">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>All Listings</h2>
    <!-- <a href="" class="btn btn-outline-dark rounded-pill"
      >Add Listing</a
    > -->
  </div>
  <div class="row g-4">
    
    <% for(listing of allListing){%>
    <div class="col-md-6 col-lg-4">
      <div class="listing-card">
        <img
          src="<%= listing.image.url%>" alt="<%=listing.image.filename%>"
        />
        <div class="p-3">
          <h5><%=listing.title%></h5>
          <p class="text-muted mb-2"><%= listing.location %></p>
          <div class="d-flex justify-content-between align-items-center">
            <strong>&#8377; <%= Number(listing.price).toLocaleString("en-IN") %> /night</strong>
            <a class="btn btn-sm btn-main rounded-pill w-25" href="/listing/<%=listing._id%>"
              >View</a
            >
          </div>
        </div>
      </div>
    </div>
    <%}%>
  </div>
</section>
<%}%>