              </div>
            </div>
            <div
              style="
                text-align: center;
                padding: 12px;
                background: var(--gold-pale);
                border-radius: var(--radius-sm);
              "
            >
              <div
                style="
                  font-family: &quot;Cormorant Garamond&quot;, serif;
                  font-size: 1.4rem;
                  font-weight: 700;
                  color: var(--gold);
                "
              >
                &lt;1hr
              </div>
              <div
                style="
                  font-size: 0.72rem;
                  color: var(--ink-soft);
                  text-transform: uppercase;
                  letter-spacing: 0.5px;
                "
              >
                Response time
              </div>
            </div>
          </div>
          <button
            style="
              width: 100%;
              background: none;
              border: 1.5px solid var(--border);
              border-radius: var(--radius-sm);
              padding: 11px;
              font-size: 0.85rem;
              font-weight: 600;
              cursor: pointer;
              color: var(--ink-mid);
              font-family: &quot;DM Sans&quot;, sans-serif;
              transition: all 0.2s;
            "
            onmouseover="
              this.style.borderColor = 'var(--gold)';
