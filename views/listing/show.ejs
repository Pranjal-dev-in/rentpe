              style="max-height: 514px;"
            />
          </div>
          <div class="photo-sub-grid">
            <div class="photo-item photo-second" onclick="openLightbox(1)">
              <%if(list.image[1]){%>
              <img
                src="<%=list.image[1].url%>"
