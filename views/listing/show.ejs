                alt="Pool"
                style="max-height: 164px;scale: 1.1;"
              /><%}%>
            </div>
            <div class="photo-item has-overlay " onclick="openLightbox(3)">
              <%if(list.image[3]){%>
              <img
                src="<%=list.image[3].url%>"
                alt="More photos"
                style="max-height: 164px;scale: 1.1;"
              /><%}%>
              <div class="photo-overlay">
                <svg
                  width="18"
                  height="18"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
