  </div>
  <!-- ── MOBILE BOOKING BAR ── -->
  <div class="mobile-booking-bar">
    <div class="mobile-price">
      <strong>₹ <%= Number(list.price).toLocaleString("en-IN") %></strong> <span>/ night · ★ 4.9</span>
    </div>
    <button class="btn-reserve-mobile">Reserve Now</button>
  </div>
  <!-- ── LIGHTBOX ── -->

  <div class="lightbox" id="lightbox">
    <div class="counter" id="counter">1 / 4</div>
    <button class="close-btn" onclick="closeLightbox()">✕</button>
    <button class="lightbox-btn prev-btn" onclick="prevPhoto()">‹</button>
    <img id="lightboxImg" />
    <button class="lightbox-btn next-btn" onclick="nextPhoto()">›</button>
  </div>


<script>
  /* Review Form Validation */
  let reviewForm = document.getElementById("reviewForm");

  reviewForm.addEventListener("submit", function (e) {
    e.preventDefault();

    let valid = true;

    const comment = document.getElementById("reviewComment");
    const commentError = comment.nextElementSibling;

    // Remove old errors
    comment.classList.remove("input-error");
    commentError.classList.remove("show");

    // Comment validation
    if (!comment.value.trim()) {
      comment.classList.add("input-error");
      commentError.classList.add("show");
      valid = false;
    }

    // Rating validation
    const rating = document.querySelector('input[name="rating"]:checked');

    if (!rating) {
      valid = false;
      alert("Please select a rating");
    }

    // Submit
    if (valid) {
      const btn = this.querySelector("button");

      btn.disabled = true;
      btn.textContent = "Submitting...";

      reviewForm.submit();
    }
  }); 
  const map = L.map("map").setView([<%=list.geometry.coordinates[1]%>,<%=list.geometry.coordinates[0]%>], 13);

      L.tileLayer(
        "https://tile.openstreetmap.org/{z}/{x}/{y}.png",
        {
          attribution: "&copy; OpenStreetMap contributors",
        }
      ).addTo(map);

      L.marker([<%=list.geometry.coordinates[1]%>,<%=list.geometry.coordinates[0]%>])
        .addTo(map)
        .bindPopup("<%=list.title%>")
        .openPopup();
    window.listImg = <%- JSON.stringify(list.image) %>;
    window.list = <%- JSON.stringify(list) %>;
</script>
