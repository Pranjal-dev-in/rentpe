            <div>
              <div style="font-weight: 700; font-size: 1rem"><%=list.owner.name%></div>
              <div style="font-size: 0.8rem; color: var(--ink-soft)">
                Hosted by Owner
              </div>
            </div>
          </div>
          <div
            style="
              display: grid;
              grid-template-columns: 1fr 1fr;
              gap: 12px;
              margin-bottom: 16px;
            "
          >
            <div
              style="
                text-align: center;
                padding: 12px;
