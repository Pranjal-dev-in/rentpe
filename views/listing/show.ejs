    </div>
    <!-- GALLERY (4 photos layout) -->
    <div class="gallery">
      <div class="gallery-wrapper">
        <div class="gallery-grid-many" id="gallery7">
          <div class="photo-item photo-main" onclick="openLightbox(0)">
            <img
              src="<%=list.image[0].url%>"
