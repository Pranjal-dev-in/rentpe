<% layout("layout/boilerplate")%>

<% if(success && success.length > 0) { %>
  <div class="action-toast-msg success">
    <i class="fa-solid fa-circle-check action-toast-tick-icon"></i> &nbsp;&nbsp;<span><%= success %></span>
  </div>
<% } %>

<!-- ── BREADCRUMB ── -->
<div class="breadcrumb">
  <a href="/listing">Home</a>
  <span>›</span>
  <!-- <a href="#">Bareilly</a>
  <span>›</span> -->
  <span style="color: var(--ink-mid); font-weight: 500"
    ><%= list.title%></span
  >
</div>
  <!-- ── MAIN ── -->
  <div class="container">
    <!-- Header -->
    <div class="listing-header">
      <div class="header-row">
        <div>
          <h1 class="listing-title"><%= list.title%></h1> 
          <div class="listing-meta">
            <div class="meta-item">
              <svg
                width="14"
                height="14"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                />
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
                />
              </svg>
              <%=list.location%>, <%=list.city%>
            </div>
            <div class="meta-item">
              <svg
                width="14"
                height="14"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"
                />
              </svg>
              Up to <%=list.guests%> Guests
            </div>
            <div class="rating-badge">
              <%if(list.reviews.length>0) {%>
                ★ <%=(list.reviews.reduce((sum, item) => sum + item.rating, 0)/list.reviews.length).toFixed(1)%>·
              <%}%>
              <span style="font-weight: 400; color: var(--gold-light)"
                > <%=list.reviews.length%> reviews</span
              >
            </div>
          </div>
        </div>
        <div class="listing-actions-top">
          
          <%if(currUser && list.owner._id.equals(currUser._id)){%>
            <button class="btn-action-sm menu-dot">
              <svg class="w-6 h-6 text-gray-800 dark:text-white" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
              <path stroke="currentColor" stroke-linecap="round" stroke-width="2" d="M6 12h.01m6 0h.01m5.99 0h.01"/>
              </svg>
            </button>

            <div class="hidden-menu-for-listing hide">
              <form action="/listing/<%=list._id%>/edit" method="get" class="hidden-menu-btn">
                <button class="btn1">Edit</button>
              </form>
              <form action="/listing/<%=list._id%>?_method=DELETE" method="post" class="hidden-menu-btn">
                <button class="btn2">Delete</button>
              </form>
            </div>
          <%}%>
          <!-- <button class="btn-action-sm">
            <svg
              width="14"
              height="14"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
