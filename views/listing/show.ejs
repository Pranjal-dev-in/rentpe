          </button> -->
          <!-- <button class="btn-reserve">Reserve Now</button> -->
          <button class="btn-contact">Contact Owner</button>
          <div class="no-charge-note">You won't be charged yet</div>
        </div>
        <!-- Host card -->
        <div
          style="
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 24px;
            margin-top: 16px;
            box-shadow: var(--shadow-sm);
