          Show all photos
        </button>
      </div>
    </div>
    <!-- CONTENT GRID -->
    <div class="content-grid">
      <!-- LEFT -->
      <div class="left-col">
        <!-- Quick Facts -->
        <div class="quick-facts">
          <div class="fact-card">
            <div class="fact-icon">🏨</div>
            <div class="fact-label">Type</div>
            <div class="fact-value"><%=list.type%></div>
          </div>
          <div class="fact-card">
            <div class="fact-icon">👥</div>
            <div class="fact-label">Guests</div>
            <div class="fact-value"><%=list.guests%> max</div>
          </div>
          <div class="fact-card">
            <div class="fact-icon">⭐</div>
            <div class="fact-label">Rating</div>
            <div class="fact-value"><%if(list.reviews.length>0){%><%=(list.reviews.reduce((sum, item) => sum + item.rating, 0)/list.reviews.length).toFixed(1)%> / 5<%} else {%>0<%}%></div>
          </div>
        </div>
        <!-- Host -->
        <div class="host-bar">
          <div class="host-avatar"><%=list.owner.name.slice(0,1).toUpperCase()%></div>
          <div class="host-info">
            <div class="host-name"><%=list.owner.name%></div>
            <div class="host-meta">
              Response rate: 98% · Usually replies within an hour
            </div>
          </div>
          <div class="superhost-badge">⚡ Superhost</div>
        </div>
        <!-- About -->
        <div class="section">
          <h2 class="section-title">About this place</h2>
          <p class="section-body" id="aboutText"><%=list.description%></p>
          <button class="read-more" onclick="toggleAbout()">
            Show more ›
          </button>
        </div>
        <!-- Amenities -->
        <div class="section">
          <h2 class="section-title">What this place offers</h2>
          <div class="amenities-grid">
            <%for(amenity of list.amenities) {%>
              <div class="amenity">
                <span class="amenity-icon"></span><%=amenity%>
              </div>
            <%}%>
          </div>
        </div>
        <!-- Map -->
        <div class="section">
          <h2 class="section-title">Where you'll be</h2>
          <p class="section-body" style="margin-bottom: 14px"><%=list.location%>, <%=list.city%></p>
          <div class="map-placeholder">
            <div id="map">

            </div>
          </div>
        </div>
        <!-- Reviews -->
        <div class="section">
          <h2 class="section-title">Guest Reviews</h2>
          <%if(list.reviews.length>0){%>
          <div class="reviews-header">
            <div class="overall-rating">
              <div class="big-score"><%=(list.reviews.reduce((sum, item) => sum + item.rating, 0)/list.reviews.length).toFixed(1)%></div>
              <div>
                <div class="stars-row">
                  <span class="star">★</span><span class="star">★</span
                  ><span class="star">★</span><span class="star">★</span
                  ><span class="star">★</span>
                </div>
                <div class="review-count"><%=list.reviews.length%> reviews</div>
              </div>
            </div>
          </div>
          <div class="rating-bars">
            <div class="rating-bar-row">
              <span class="bar-label">Cleanliness</span>
              <div class="bar-track">
                <div class="bar-fill" style="width: 96%"></div>
              </div>
              <span class="bar-val">4.9</span>
            </div>
            <div class="rating-bar-row">
              <span class="bar-label">Location</span>
              <div class="bar-track">
                <div class="bar-fill" style="width: 94%"></div>
              </div>
              <span class="bar-val">4.7</span>
            </div>
            <div class="rating-bar-row">
              <span class="bar-label">Value</span>
              <div class="bar-track">
                <div class="bar-fill" style="width: 92%"></div>
              </div>
              <span class="bar-val">4.6</span>
            </div>
            <div class="rating-bar-row">
              <span class="bar-label">Service</span>
              <div class="bar-track">
                <div class="bar-fill" style="width: 98%"></div>
              </div>
              <span class="bar-val">4.9</span>
            </div>
          </div>
          <%}%>
          <div class="reviews-grid">
            <%if(list.reviews.length>0) {%>
              <%for(review of list.reviews) {%>
                <div class="review-card">
                  <div class="reviewer-row">
                    <div class="reviewer-avatar"><%=review.written.name.slice(0,1).toUpperCase()%></div>
                    <div>
                      <div class="reviewer-name"><%=review.written.name%></div>
                      <div class="reviewer-date">May 2026</div>
                    </div>
                  </div>
                  <p class="starability-result" data-rating="<%= review.rating %>" style="scale: 0.5; left: -35px;">Rated: <%= review.rating %> stars</p>
                  <p class="review-text"><%=review.comment%></p>
                </div>
              <%}%>
            <%}else{%>
              <p class="review-text" style="margin-left: 10px;">No reviews yet. Be the first to review!</p>
            <%}%>
          </div>
          <%if(list.reviews.length>4) {%>
            <button class="see-all-reviews">View all <%=list.reviews.length%> reviews →</button>
          <%}%>
          
          <!-- Write a Review -->
          <form action="/listing/<%= list._id %>/review" method="POST" novalidate id="reviewForm"
            style="
              background: var(--white);
              border: 1px solid var(--border);
              border-radius: var(--radius);
              padding: 28px;
              margin-top: 28px;
              box-shadow: var(--shadow-sm);
            "
          >
            <h3
              style="
                font-family: &quot;Cormorant Garamond&quot;, serif;
                font-size: 1.4rem;
                font-weight: 600;
                margin-bottom: 20px;
              "
            >
              Write a Review
            </h3>
            <div style="margin-bottom: 16px">
              <label
                style="
                  font-size: 0.8rem;
                  font-weight: 600;
                  text-transform: uppercase;
                  letter-spacing: 0.8px;
                  color: var(--ink-soft);
                  display: block;
                  margin-bottom: 8px;
                "
                >Rating</label
              >
              <div id="starRating" style="display: flex; gap: 6px">
                <fieldset class="starability-fade"> 
                  <input type="radio" id="no-rate" class="input-no-rate" name="rating" value="1" checked aria-label="No rating." />
                  <input type="radio" id="first-rate1" name="rating" value="1" />
                  <label for="first-rate1" title="Terrible">1 star</label>
                  <input type="radio" id="first-rate2" name="rating" value="2" />
                  <label for="first-rate2" title="Not good">2 stars</label>
                  <input type="radio" id="first-rate3" name="rating" value="3" />
                  <label for="first-rate3" title="Average">3 stars</label>
                  <input type="radio" id="first-rate4" name="rating" value="4" />
                  <label for="first-rate4" title="Very good">4 stars</label>
                  <input type="radio" id="first-rate5" name="rating" value="5" />
                  <label for="first-rate5" title="Amazing">5 stars</label>
                </fieldset>
              </div>
            </div>
            <div style="margin-bottom: 16px">
              <label
                style="
                  font-size: 0.8rem;
                  font-weight: 600;
                  text-transform: uppercase;
                  letter-spacing: 0.8px;
                  color: var(--ink-soft);
                  display: block;
                  margin-bottom: 8px;
                "
                >Comment</label
              >
              <textarea
                id="reviewComment"
                rows="4"
                placeholder="Write your experience..."
                name="comment"
                required
                style="
                  width: 100%;
                  border-radius: var(--radius-sm);
                  padding: 12px 14px;
                  font-family: &quot;DM Sans&quot;, sans-serif;
                  font-size: 0.9rem;
                  color: var(--ink);
                  resize: vertical;
                  outline: none;
                  transition: border-color 0.2s;
                "
                onfocus="this.style.borderColor = 'var(--gold)'"
                onblur="this.style.borderColor = 'var(--border)'"
              ></textarea>
              <div class="invalid-feedback">
                &nbsp;&nbsp;Please enter your valuable experience.
              </div>
            </div>
            <button
            type="submit"
              style="
                background: linear-gradient(135deg, var(--gold), #b07d28);
                color: white;
                border: none;
                border-radius: var(--radius-sm);
                padding: 12px 28px;
                font-size: 0.9rem;
                font-weight: 700;
                cursor: pointer;
                font-family: &quot;DM Sans&quot;, sans-serif;
                transition: all 0.2s;
              "
              onmouseover="this.style.transform = 'translateY(-1px)'"
              onmouseout="this.style.transform = ''"
            >
              Submit Review
            </button>

          </form>
        </div>
      </div>
      <!-- RIGHT (Booking Card) -->
      <div class="right-col">
        <div class="booking-card">
          <div class="price-line">
            <span class="price-amount">₹ <%= Number(list.price).toLocaleString("en-IN") %></span>
